NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/earnhub
JWT_SECRET=replace-with-a-long-random-secret

# OTP and temporary registration policy
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
OTP_VERIFICATION_LOCK_SECONDS=60
PENDING_REGISTRATION_TTL_MINUTES=30

# Generic SMTP configuration. For Gmail, use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-provider-app-password-or-smtp-key

# This address/domain must be verified with your email provider.
EMAIL_FROM="EarnHub <your-email@gmail.com>"
EMAIL_REPLY_TO=support@example.com

# Used only by `npm run email:check` to send a real delivery test.
EMAIL_TEST_TO=your-test-inbox@example.com

# Resend alternative:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key
# EMAIL_FROM="EarnHub <verify@your-verified-domain.com>"
